<script>
  // Scroll reveals: observe once, add .is-in, unobserve. Passive by nature;
  // no layout reads interleaved with writes.
  const revealables = document.querySelectorAll<HTMLElement>(".reveal");

  if ("IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-in");
            observer.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px" },
    );

    for (const el of revealables) observer.observe(el);
  } else {
    for (const el of revealables) el.classList.add("is-in");
  }

  // Scrollable code regions must be keyboard-reachable (WCAG 2.1.1 /
  // axe scrollable-region-focusable). Our own snippets carry tabindex in
  // markup; this pass covers rendered CodeBlocks, skipping the aria-hidden
  // demo pane (focusable content inside aria-hidden is its own violation).
  for (const el of document.querySelectorAll<HTMLElement>("pre, pre > code")) {
    if (el.closest('[aria-hidden="true"]')) continue;
    const style = getComputedStyle(el);
    if ((style.overflowX === "auto" || style.overflowX === "scroll") && el.tabIndex < 0) {
      el.tabIndex = 0;
    }
  }

  // Copy buttons: clipboard write, icon cross-fade via data-state, and a
  // polite live-region announcement for screen readers.
  for (const button of document.querySelectorAll<HTMLButtonElement>("[data-copy]")) {
    button.addEventListener("click", async () => {
      const text = button.dataset.copy;
      if (!text) return;

      try {
        await navigator.clipboard.writeText(text);
      } catch {
        return;
      }

      button.dataset.state = "copied";
      const live = button.querySelector("[data-copy-live]");
      if (live) live.textContent = "Copied to clipboard";

      window.setTimeout(() => {
        delete button.dataset.state;
        if (live) live.textContent = "";
      }, 2000);
    });
  }
</script>
