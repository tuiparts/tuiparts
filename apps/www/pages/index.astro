---
import data from "blume:data";
import CodeBlock from "blume/components/content/CodeBlock.astro";
import PageLayout from "blume/components/layout/PageLayout.astro";

const { config } = data;

const installCommand =
  "pnpm add @tuiparts/react @tuiparts/core @opentui/core @opentui/react react";

const recipeCommand = "pnpm dlx shadcn@4.13.0 add @tuiparts/react/checkbox";

const primitiveSource = `import { Checkbox as CheckboxPrimitive } from "@tuiparts/react/checkbox";

export function Checkbox() {
  return (
    <CheckboxPrimitive.Root defaultChecked flexDirection="row" gap={1}>
      {(state) => (
        <>
          <CheckboxPrimitive.Indicator>
            <text content="✓" />
          </CheckboxPrimitive.Indicator>
          <text content={state.checked ? "Enabled" : "Disabled"} />
        </>
      )}
    </CheckboxPrimitive.Root>
  );
}`;

const packagedOwns = [
  "focus management",
  "keyboard activation",
  "pointer events",
  "collections",
  "overlay layering",
  "lifecycle",
];

const copiedOwns = [
  "glyphs and marks",
  "palettes",
  "density and layout",
  "semantic variants",
  "labels",
  "convenience props",
];

const catalog = [
  {
    href: "/docs/catalog/button",
    label: "Button",
    parts: "pressed · focused · disabled",
  },
  {
    href: "/docs/catalog/checkbox",
    label: "Checkbox",
    parts: "Root · Indicator",
  },
  { href: "/docs/catalog/switch", label: "Switch", parts: "Root · Thumb" },
  {
    href: "/docs/catalog/toggle",
    label: "Toggle",
    parts: "pressed · focused · disabled",
  },
  {
    href: "/docs/catalog/toggle-group",
    label: "Toggle Group",
    parts: "single · multiple · roving focus",
  },
  {
    href: "/docs/catalog/radio-group",
    label: "Radio Group",
    parts: "roving arrow-key focus",
  },
  {
    href: "/docs/catalog/input",
    label: "Input",
    parts: "input · change · submit",
  },
  {
    href: "/docs/catalog/badge",
    label: "Badge",
    parts: "presentation-only",
  },
  {
    href: "/docs/catalog/dialog",
    label: "Dialog",
    parts: "overlay · focus containment",
  },
];

const pillars = [
  {
    title: "One vocabulary, three runtimes",
    body: "React and Solid adapters sit over the same Core Stores and Renderables — which you can also drive imperatively.",
  },
  {
    title: "shadcn-compatible registry",
    body: "Recipes install with the official shadcn CLI and update through the standard view, diff, and add lifecycle.",
  },
  {
    title: "AI-ready docs",
    body: "Every page is available as raw Markdown, with llms.txt generated for coding agents and assistants.",
  },
];
---

<PageLayout
  site={{ title: config.title, description: config.description }}
  logo={config.logo}
  banner={config.banner}
  analytics={config.analytics}
  navigation={data.navigation}
  favicon={config.favicon}
  fontCssVars={data.fontCssVars}
  themeMode={config.theme.mode}
  searchEnabled={config.search.enabled}
  siteUrl={config.site}
  ogEnabled={config.og.enabled}
  page={{
    title: "tuiparts.sh — Primitives and recipes for your terminal UI",
    description: config.description,
  }}
>
  <script is:inline>document.documentElement.classList.add("js");</script>

  {/* ── Hero — title left, live terminal render right ── */}
  <section
    class="mx-auto grid max-w-6xl items-center gap-12 px-6 pt-14 pb-20 lg:grid-cols-[minmax(0,10fr)_minmax(0,9fr)] lg:gap-16 lg:pt-20 lg:pb-28"
  >
    <div>
      <p
        class="inline-flex items-center gap-2 font-mono text-xs tracking-[0.12em] text-muted-foreground uppercase"
      >
        <span class="text-accent" aria-hidden="true">●</span> Packages · recipes
      </p>
      <h1
        class="mt-5 max-w-xl text-balance font-display text-4xl font-semibold tracking-tight text-foreground sm:text-5xl lg:text-6xl"
      >
        Parts for your <span class="text-accent">terminal</span> UI.
      </h1>
      <p class="mt-6 max-w-lg text-pretty text-lg leading-8 text-muted-foreground">
        Composable interaction primitives and editable recipes for{" "}
        <a
          class="font-medium text-foreground underline decoration-border underline-offset-4 transition-colors hover:decoration-accent"
          href="https://github.com/anomalyco/opentui">OpenTUI</a
        >. Behavior ships as versioned packages. Presentation installs as
        source you own.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a class="btn-solid press rounded-blume px-5 py-2.5 text-sm font-medium" href="/docs"
          >Read the docs</a
        >
        <a
          class="btn-outline press rounded-blume border border-border px-5 py-2.5 text-sm font-medium text-foreground"
          href="/docs/catalog">Browse the catalog</a
        >
      </div>
      <div
        class="mt-8 flex max-w-lg items-center gap-1 rounded-blume border border-border bg-muted/60 py-1 pr-1 pl-4"
      >
        <code
          tabindex="0"
          class="min-w-0 flex-1 overflow-x-auto py-2 font-mono text-xs whitespace-nowrap text-muted-foreground [scrollbar-width:none]"
          >{installCommand}</code
        >
        <button
          type="button"
          class="copy-btn press relative shrink-0 rounded-[calc(var(--blume-radius)-0.25rem)] p-2.5 text-muted-foreground transition-colors hover:bg-background hover:text-foreground"
          data-copy={installCommand}
          aria-label="Copy install command"
        >
          <svg
            class="icon-copy size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect width="14" height="14" x="8" y="8" rx="2"></rect>
            <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
          </svg>
          <svg
            class="icon-check size-4 text-accent"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M20 6 9 17l-5-5"></path>
          </svg>
          <span class="sr-only" aria-live="polite" data-copy-live></span>
        </button>
      </div>
    </div>

    <figure
      class="demo m-0"
      role="img"
      aria-label="Terminal running settings.tsx built with tuiparts.sh: a checkbox list, a radio-group theme picker, a switch, a focused search input, and Save and Cancel buttons."
    >
      <div class="demo-bar">
        <span class="demo-file">demo/settings.tsx</span>
        <span class="demo-meta"><span class="demo-dot" aria-hidden="true"></span>opentui · react</span>
      </div>
      <div class="demo-screen" aria-hidden="true">
        <div class="demo-line demo-cmd"><span class="t-signal">❯</span> <span class="typed">bun run settings.tsx</span><span class="caret-cmd">▍</span></div>
        <div class="demo-ui">
          <div class="demo-line t-bright demo-gap">Settings</div>
          <div class="demo-line t-faint">────────────────────────────────</div>
          <div class="demo-line demo-gap"><span class="t-dim">[</span><span class="t-signal">✓</span><span class="t-dim">]</span> Enable notifications</div>
          <div class="demo-line"><span class="t-dim">[ ]</span> Auto-install updates</div>
          <div class="demo-line demo-gap">Theme      <span class="t-dim">(</span><span class="t-signal">●</span><span class="t-dim">)</span> Dark   <span class="t-dim">( )</span> Light</div>
          <div class="demo-line demo-gap">Telemetry  <span class="t-dim">○──</span>  <span class="t-muted">off</span></div>
          <div class="demo-line demo-gap"><span class="t-signal">┃</span> <span class="caret-input">▍</span><span class="t-muted">Search the catalog…</span></div>
          <div class="demo-line demo-gap"><span class="chip chip-solid"> Save changes </span>  <span class="chip chip-ghost"> Cancel </span></div>
          <div class="demo-line t-faint demo-gap">tab focus · space toggle · ↵ submit</div>
        </div>
      </div>
    </figure>
  </section>

  {/* ── The trade — one statement, two owners ── */}
  <section class="border-t border-border">
    <div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
      <h2
        class="reveal max-w-2xl text-balance font-display text-3xl font-semibold tracking-tight text-foreground sm:text-4xl"
      >
        Package the difficult behavior. Copy the opinionated layer.
      </h2>
      <p class="reveal mt-4 max-w-2xl text-pretty text-muted-foreground" data-d="1">
        The same split Base UI and shadcn/ui made on the web, applied to the
        terminal. Correctness-critical behavior is centralized and tested
        once; everything opinionated stays in code you can read and change.
      </p>
      <div class="mt-14 grid gap-12 lg:grid-cols-2 lg:gap-0">
        <div class="reveal lg:border-r lg:border-border lg:pr-12" data-d="1">
          <p class="font-mono text-xs tracking-[0.14em] text-accent uppercase">
            01 · Shipped as packages
          </p>
          <h3 class="mt-3 font-display text-xl font-semibold text-foreground">
            Behavior, versioned
          </h3>
          <p class="mt-3 text-pretty text-sm leading-6 text-muted-foreground">
            The parts that are hard to get right and expensive to maintain.
            Upgrades deliver fixes, not surprises.
          </p>
          <ul class="mt-6 grid grid-cols-2 gap-x-6 gap-y-2.5">
            {
              packagedOwns.map((item) => (
                <li class="flex items-baseline gap-2.5 font-mono text-xs text-muted-foreground">
                  <span class="text-accent" aria-hidden="true">
                    ▪
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
        <div class="reveal lg:pl-12" data-d="2">
          <p class="font-mono text-xs tracking-[0.14em] text-accent uppercase">
            02 · Copied as source
          </p>
          <h3 class="mt-3 font-display text-xl font-semibold text-foreground">
            Presentation, yours
          </h3>
          <p class="mt-3 text-pretty text-sm leading-6 text-muted-foreground">
            Plain TypeScript installed into your project. Edit anything;
            there is no hidden theme runtime.
          </p>
          <ul class="mt-6 grid grid-cols-2 gap-x-6 gap-y-2.5">
            {
              copiedOwns.map((item) => (
                <li class="flex items-baseline gap-2.5 font-mono text-xs text-muted-foreground">
                  <span class="text-accent" aria-hidden="true">
                    ▪
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* ── Primitives — for system builders ── */}
  <section class="border-t border-border">
    <div
      class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-20 lg:grid-cols-2 lg:gap-16 lg:py-24"
    >
      <div class="reveal">
        <h2
          class="text-balance font-display text-3xl font-semibold tracking-tight text-foreground"
        >
          When you're building a system.
        </h2>
        <p class="mt-4 text-pretty leading-7 text-muted-foreground">
          Compound parts with readonly state callbacks and real Renderable
          refs. Controlled or uncontrolled ownership, keyboard and pointer
          activation, focus, and overlay layering — solved once, versioned,
          and tested.
        </p>
        <ul class="mt-6 space-y-2.5">
          <li class="flex items-baseline gap-2.5 font-mono text-xs text-muted-foreground">
            <span class="text-accent" aria-hidden="true">▪</span> readonly state callbacks — no wrapper components
          </li>
          <li class="flex items-baseline gap-2.5 font-mono text-xs text-muted-foreground">
            <span class="text-accent" aria-hidden="true">▪</span> real parts: Root, Indicator, Thumb, Popup
          </li>
          <li class="flex items-baseline gap-2.5 font-mono text-xs text-muted-foreground">
            <span class="text-accent" aria-hidden="true">▪</span> controlled or uncontrolled — you decide
          </li>
        </ul>
        <a class="link-arrow mt-8 inline-flex items-center gap-1.5 text-sm font-medium text-accent" href="/docs/quickstart"
          >Read the quick start <span class="arrow" aria-hidden="true">→</span></a
        >
      </div>
      <div class="reveal" data-d="1">
        <CodeBlock code={primitiveSource} lang="tsx" icons={false} />
      </div>
    </div>
  </section>

  {/* ── Graphite band — recipes + the catalog index ── */}
  <section class="band">
    <div
      class="mx-auto grid max-w-6xl gap-14 px-6 py-20 lg:grid-cols-[minmax(0,10fr)_minmax(0,9fr)] lg:gap-20 lg:py-24"
    >
      <div class="reveal">
        <h2 class="text-balance font-display text-3xl font-semibold tracking-tight">
          When you want a head start.
        </h2>
        <p class="band-muted mt-4 text-pretty leading-7">
          One command copies an editable component into your project — built
          on the packaged primitives, with a starter palette, glyphs, and
          variants that are yours to change. Review upstream changes later
          with shadcn's diff workflow; nothing overwrites your edits.
        </p>
        <div class="band-cmd mt-8">
          <span class="t-signal shrink-0" aria-hidden="true">❯</span>
          <code
            tabindex="0"
            class="min-w-0 flex-1 overflow-x-auto whitespace-nowrap [scrollbar-width:none]"
            >{recipeCommand}</code
          >
          <button
            type="button"
            class="copy-btn copy-btn-band press relative shrink-0 rounded-[4px] p-2"
            data-copy={recipeCommand}
            aria-label="Copy recipe install command"
          >
            <svg
              class="icon-copy size-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect width="14" height="14" x="8" y="8" rx="2"></rect>
              <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
            </svg>
            <svg
              class="icon-check size-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M20 6 9 17l-5-5"></path>
            </svg>
            <span class="sr-only" aria-live="polite" data-copy-live></span>
          </button>
        </div>
        <a class="band-link link-arrow mt-8 inline-flex items-center gap-1.5 text-sm font-medium" href="/docs/registry"
          >How the registry works <span class="arrow" aria-hidden="true">→</span></a
        >
      </div>
      <div class="reveal" data-d="1">
        <h3 class="font-display text-base font-semibold text-[var(--tp-graphite-ink)]">
          Starter catalog
        </h3>
        <ol class="band-list mt-5">
          {
            catalog.map((item, index) => (
              <li>
                <a class="band-row" href={item.href}>
                  <span class="band-index">{String(index + 1).padStart(2, "0")}</span>
                  <span class="band-name">{item.label}</span>
                  <span class="band-parts">{item.parts}</span>
                  <span class="band-arrow" aria-hidden="true">
                    →
                  </span>
                </a>
              </li>
            ))
          }
        </ol>
        <p class="band-muted mt-5 font-mono text-xs">
          Every recipe ships for Core, React, and Solid.
        </p>
      </div>
    </div>
  </section>

  {/* ── Pillars — asymmetric, hairline-divided, no boxes ── */}
  <section class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
    <div class="grid gap-10 lg:grid-cols-[1.35fr_1fr_1fr] lg:gap-0">
      {
        pillars.map((pillar, index) => (
          <div
            class:list={[
              "reveal",
              index === 0 && "lg:pr-14",
              index > 0 && "lg:border-l lg:border-border lg:pl-10",
              index === 1 && "lg:pr-10",
            ]}
            data-d={String(index)}
          >
            <h3
              class:list={[
                "text-balance font-display font-semibold text-foreground",
                index === 0 ? "text-xl" : "text-lg",
              ]}
            >
              {pillar.title}
            </h3>
            <p class="mt-3 text-pretty text-sm leading-6 text-muted-foreground">{pillar.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  {/* ── Closing CTA ── */}
  <section class="border-t border-border">
    <div class="mx-auto max-w-4xl px-6 py-24 text-center lg:py-28">
      <h2
        class="reveal mx-auto max-w-2xl text-balance font-display text-3xl font-semibold tracking-tight text-foreground sm:text-4xl"
      >
        Build your terminal UI from parts.
      </h2>
      <p class="reveal mx-auto mt-4 max-w-xl text-pretty text-muted-foreground" data-d="1">
        Behavior in packages. Presentation in your repo. Free and open source
        under MIT.
      </p>
      <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-3" data-d="2">
        <a class="btn-solid press rounded-blume px-5 py-2.5 text-sm font-medium" href="/docs/quickstart"
          >Quick start</a
        >
        <a
          class="btn-outline press rounded-blume border border-border px-5 py-2.5 text-sm font-medium text-foreground"
          href="https://github.com/tuiparts/tuiparts">View the code</a
        >
      </div>
    </div>
  </section>

  <footer slot="footer" class="border-t border-border">
    <div
      class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-10 px-6 py-14 sm:flex-row"
    >
      <div class="max-w-xs">
        <p class="font-display text-sm font-semibold text-foreground">tuiparts.sh</p>
        <p class="mt-2 text-pretty text-sm text-muted-foreground">
          Terminal primitives and editable recipes for OpenTUI.
        </p>
        <p class="mt-5 font-mono text-xs text-muted-foreground">
          <span class="text-accent" aria-hidden="true">●</span> MIT licensed
        </p>
      </div>
      <div class="grid grid-cols-2 gap-x-14 gap-y-10 sm:grid-cols-3">
        <div>
          <p class="font-mono text-xs tracking-[0.14em] text-muted-foreground uppercase">Docs</p>
          <ul class="mt-4 space-y-2.5 text-sm">
            <li>
              <a class="footer-link" href="/docs">Introduction</a>
            </li>
            <li>
              <a class="footer-link" href="/docs/quickstart">Quick start</a>
            </li>
            <li>
              <a class="footer-link" href="/docs/catalog">Catalog</a>
            </li>
            <li>
              <a class="footer-link" href="/docs/registry">Registry</a>
            </li>
          </ul>
        </div>
        <div>
          <p class="font-mono text-xs tracking-[0.14em] text-muted-foreground uppercase">
            Packages
          </p>
          <ul class="mt-4 space-y-2.5 text-sm">
            <li>
              <a class="footer-link" href="https://www.npmjs.com/package/@tuiparts/core"
                >@tuiparts/core</a
              >
            </li>
            <li>
              <a class="footer-link" href="https://www.npmjs.com/package/@tuiparts/react"
                >@tuiparts/react</a
              >
            </li>
            <li>
              <a class="footer-link" href="https://www.npmjs.com/package/@tuiparts/solid"
                >@tuiparts/solid</a
              >
            </li>
          </ul>
        </div>
        <div>
          <p class="font-mono text-xs tracking-[0.14em] text-muted-foreground uppercase">
            Community
          </p>
          <ul class="mt-4 space-y-2.5 text-sm">
            <li>
              <a class="footer-link" href="https://github.com/tuiparts/tuiparts">GitHub</a>
            </li>
            <li>
              <a class="footer-link" href="https://github.com/anomalyco/opentui">OpenTUI</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </footer>
</PageLayout>

<style>
  /* Hallmark · genre: modern-minimal · macrostructure: dev-tool/CLI · theme: cobalt-deep
     · enrichment: Tier-A CSS art (TUI instrument pane) · nav: blume-default
     · footer: Ft3 (docs-root allowance) · design-system: design.md · designed-as-app
     · contrast: pass (40–41) · responsive: pass (34, 49–57)
     · pre-emit critique: P5 H5 E5 S5 R5 V5 */

  /* ── CTAs ─────────────────────────────────────────────────────────── */

  .press {
    transition: transform 150ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .press:active {
    transform: scale(0.97);
  }

  .btn-solid {
    display: inline-flex;
    min-height: 2.5rem;
    align-items: center;
    background: var(--blume-action);
    color: var(--blume-action-foreground);
    transition:
      background-color 150ms ease,
      transform 150ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .btn-solid:hover {
    background: var(--tp-action-hover);
  }

  .btn-outline {
    display: inline-flex;
    min-height: 2.5rem;
    align-items: center;
    transition:
      border-color 150ms ease,
      background-color 150ms ease,
      transform 150ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .btn-outline:hover {
    border-color: var(--blume-accent);
  }

  .link-arrow .arrow {
    display: inline-block;
    transition: transform 150ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  @media (hover: hover) and (pointer: fine) {
    .link-arrow:hover .arrow {
      transform: translateX(2px);
    }
  }

  .footer-link {
    color: var(--blume-foreground);
    transition: color 150ms ease;
  }

  .footer-link:hover {
    color: var(--blume-accent);
  }

  /* ── Copy button — clipboard ⇢ check cross-fade ───────────────────── */

  .copy-btn {
    min-width: 2.5rem;
    min-height: 2.5rem;
  }

  .copy-btn svg {
    transition:
      opacity 300ms cubic-bezier(0.2, 0, 0, 1),
      transform 300ms cubic-bezier(0.2, 0, 0, 1),
      filter 300ms cubic-bezier(0.2, 0, 0, 1);
  }

  .copy-btn .icon-check {
    position: absolute;
    inset: 0;
    margin: auto;
    opacity: 0;
    transform: scale(0.25);
    filter: blur(4px);
  }

  .copy-btn[data-state="copied"] .icon-copy {
    opacity: 0;
    transform: scale(0.25);
    filter: blur(4px);
  }

  .copy-btn[data-state="copied"] .icon-check {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
  }

  /* ── The instrument pane — a real TUI render, fixed graphite ──────── */

  .demo {
    background: var(--tp-graphite);
    border: 1px solid var(--tp-graphite-rule);
    border-radius: 10px;
    box-shadow:
      0 1px 2px var(--tp-demo-shadow-near),
      0 12px 32px var(--tp-demo-shadow-far);
    overflow: hidden;
  }

  .demo-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
