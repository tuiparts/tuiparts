{
  "name": "opentui-ui",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "keywords": [
    "ui",
    "opentui",
    "opentui-ui"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "lint": "biome check .",
    "format": "biome check --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "test": "pnpm -r --if-present test",
    "validate:packages": "pnpm build && node scripts/validate-packages.mjs",
    "validate:packages:built": "node scripts/validate-packages.mjs",
    "validate:registry": "node scripts/validate-registry.mjs",
    "create": "./scripts/create-package.sh"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "^2.5.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "publint": "^0.3.21",
    "typescript": "^5.9.3"
  }
}
