{
  "name": "tuiparts",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "keywords": [
    "ui",
    "opentui",
    "tuiparts"
  ],
  "scripts": {
    "build": "pnpm -r --filter=!www build",
    "docs:dev": "pnpm --filter=www dev",
    "docs:build": "pnpm --filter=www build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "lint": "biome check .",
    "format": "biome check --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "test": "pnpm -r --if-present test",
    "validate:packages": "pnpm build && node scripts/validate-packages.mjs",
    "validate:packages:built": "node scripts/validate-packages.mjs",
    "validate:registry": "node scripts/validate-registry.mjs",
    "validate:registry:built": "node scripts/validate-registry.mjs --built",
    "registry:build": "node scripts/build-registry.mjs",
    "changeset:status": "changeset status",
    "validate:release-scope": "node scripts/validate-foundation-release.mjs",
    "validate:foundation": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm validate:packages:built && pnpm validate:registry:built && pnpm validate:release-scope",
    "create": "./scripts/create-package.sh",
    "fixtures:setup": "node fixtures/setup.mjs",
    "fixtures:dev": "pnpm --dir fixtures/demo dev"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "^2.5.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "publint": "^0.3.21",
    "semver": "^7.7.2",
    "shadcn": "4.13.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@6.1.0": "6.3.0"
    }
  }
}
