{
  "name": "@opentui-ui/react",
  "version": "0.0.2",
  "description": "React bindings for OpenTUI UI components",
  "author": "Matt Simpson",
  "license": "MIT",
  "sideEffects": [
    "./dist/button/**",
    "./dist/checkbox/**",
    "./dist/dialog/**",
    "./dist/input/**",
    "./dist/radio/**",
    "./dist/radio-group/**",
    "./dist/switch/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msmps/opentui-ui.git",
    "directory": "packages/react"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./button": "./src/button/index.tsx",
    "./checkbox": "./src/checkbox/index.tsx",
    "./dialog": "./src/dialog/index.ts",
    "./input": "./src/input/index.tsx",
    "./radio": "./src/radio/index.tsx",
    "./radio-group": "./src/radio-group/index.tsx",
    "./switch": "./src/switch/index.tsx"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./button": {
        "types": "./dist/button/index.d.mts",
        "import": "./dist/button/index.mjs"
      },
      "./checkbox": {
        "types": "./dist/checkbox/index.d.mts",
        "import": "./dist/checkbox/index.mjs"
      },
      "./dialog": {
        "types": "./dist/dialog/index.d.mts",
        "import": "./dist/dialog/index.mjs"
      },
      "./input": {
        "types": "./dist/input/index.d.mts",
        "import": "./dist/input/index.mjs"
      },
      "./radio": {
        "types": "./dist/radio/index.d.mts",
        "import": "./dist/radio/index.mjs"
      },
      "./radio-group": {
        "types": "./dist/radio-group/index.d.mts",
        "import": "./dist/radio-group/index.mjs"
      },
      "./switch": {
        "types": "./dist/switch/index.d.mts",
        "import": "./dist/switch/index.mjs"
      }
    }
  },
  "bugs": {
    "url": "https://github.com/msmps/opentui-ui/issues"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/msmps/opentui-ui#readme",
  "keywords": [
    "react",
    "ui",
    "components",
    "tui",
    "terminal",
    "cli",
    "opentui"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentui-ui/core": "workspace:^"
  },
  "devDependencies": {
    "@opentui/core": "catalog:",
    "@opentui/react": "catalog:",
    "@types/bun": "^1.3.14",
    "@types/node": "catalog:",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "tsdown": "^0.22.5",
    "typescript": "^5.9.3",
    "ws": "catalog:"
  },
  "peerDependencies": {
    "@opentui/core": "catalog:",
    "@opentui/react": "catalog:",
    "react": ">=19.2.0 <20",
    "ws": "catalog:"
  }
}
