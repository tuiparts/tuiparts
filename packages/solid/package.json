{
  "name": "@opentui-ui/solid",
  "version": "0.0.2",
  "description": "Solid bindings for OpenTUI UI components",
  "author": "Matt Simpson",
  "license": "MIT",
  "sideEffects": [
    "./dist/badge/**",
    "./dist/button/**",
    "./dist/checkbox/**",
    "./dist/dialog/**",
    "./dist/input/**",
    "./dist/radio/**",
    "./dist/switch/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msmps/opentui-ui.git",
    "directory": "packages/solid"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./badge": "./src/badge/index.tsx",
    "./button": "./src/button/index.tsx",
    "./checkbox": "./src/checkbox/index.tsx",
    "./dialog": "./src/dialog/index.ts",
    "./input": "./src/input/index.tsx",
    "./radio": "./src/radio/index.tsx",
    "./switch": "./src/switch/index.tsx",
    "./styled": "./src/styled.ts"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./badge": {
        "types": "./dist/badge/index.d.mts",
        "import": "./dist/badge/index.mjs"
      },
      "./button": {
        "types": "./dist/button/index.d.mts",
        "import": "./dist/button/index.mjs"
      },
      "./checkbox": {
        "types": "./dist/checkbox/index.d.mts",
        "import": "./dist/checkbox/index.mjs"
      },
      "./dialog": {
        "types": "./dist/dialog/index.d.mts",
        "import": "./dist/dialog/index.mjs"
      },
      "./input": {
        "types": "./dist/input/index.d.mts",
        "import": "./dist/input/index.mjs"
      },
      "./radio": {
        "types": "./dist/radio/index.d.mts",
        "import": "./dist/radio/index.mjs"
      },
      "./switch": {
        "types": "./dist/switch/index.d.mts",
        "import": "./dist/switch/index.mjs"
      },
      "./styled": {
        "types": "./dist/styled.d.mts",
        "import": "./dist/styled.mjs"
      }
    }
  },
  "bugs": {
    "url": "https://github.com/msmps/opentui-ui/issues"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/msmps/opentui-ui#readme",
  "keywords": [
    "solid",
    "ui",
    "components",
    "tui",
    "terminal",
    "cli",
    "opentui"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test --preload @opentui/solid/preload",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentui-ui/core": "workspace:^",
    "@opentui-ui/styles": "workspace:^"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:",
    "@types/bun": "^1.3.14",
    "@types/node": "catalog:",
    "babel-preset-solid": "1.9.12",
    "solid-js": "1.9.12",
    "tsdown": "^0.22.5",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:",
    "solid-js": "1.9.12"
  }
}
