{
  "name": "@tuiparts/solid",
  "version": "0.0.3",
  "description": "Solid Adapter for tuiparts.sh Primitives",
  "author": "Matt Simpson",
  "license": "MIT",
  "sideEffects": [
    "./dist/button/**",
    "./dist/checkbox/**",
    "./dist/dialog/**",
    "./dist/input/**",
    "./dist/radio/**",
    "./dist/radio-group/**",
    "./dist/switch/**",
    "./dist/tabs/**",
    "./dist/textarea/**",
    "./dist/toggle/**",
    "./dist/toggle-group/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuiparts/tuiparts.git",
    "directory": "packages/solid"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./button": "./src/button/index.tsx",
    "./checkbox": "./src/checkbox/index.tsx",
    "./dialog": "./src/dialog/index.ts",
    "./input": "./src/input/index.tsx",
    "./radio": "./src/radio/index.tsx",
    "./radio-group": "./src/radio-group/index.tsx",
    "./switch": "./src/switch/index.tsx",
    "./tabs": "./src/tabs/index.ts",
    "./textarea": "./src/textarea/index.tsx",
    "./toggle": "./src/toggle/index.tsx",
    "./toggle-group": "./src/toggle-group/index.tsx"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./button": {
        "types": "./dist/button/index.d.mts",
        "import": "./dist/button/index.mjs"
      },
      "./checkbox": {
        "types": "./dist/checkbox/index.d.mts",
        "import": "./dist/checkbox/index.mjs"
      },
      "./dialog": {
        "types": "./dist/dialog/index.d.mts",
        "import": "./dist/dialog/index.mjs"
      },
      "./input": {
        "types": "./dist/input/index.d.mts",
        "import": "./dist/input/index.mjs"
      },
      "./radio": {
        "types": "./dist/radio/index.d.mts",
        "import": "./dist/radio/index.mjs"
      },
      "./radio-group": {
        "types": "./dist/radio-group/index.d.mts",
        "import": "./dist/radio-group/index.mjs"
      },
      "./switch": {
        "types": "./dist/switch/index.d.mts",
        "import": "./dist/switch/index.mjs"
      },
      "./tabs": {
        "types": "./dist/tabs/index.d.mts",
        "import": "./dist/tabs/index.mjs"
      },
      "./textarea": {
        "types": "./dist/textarea/index.d.mts",
        "import": "./dist/textarea/index.mjs"
      },
      "./toggle": {
        "types": "./dist/toggle/index.d.mts",
        "import": "./dist/toggle/index.mjs"
      },
      "./toggle-group": {
        "types": "./dist/toggle-group/index.d.mts",
        "import": "./dist/toggle-group/index.mjs"
      }
    }
  },
  "bugs": {
    "url": "https://github.com/tuiparts/tuiparts/issues"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/tuiparts/tuiparts#readme",
  "keywords": [
    "solid",
    "ui",
    "components",
    "tui",
    "terminal",
    "cli",
    "opentui"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test --preload @opentui/solid/preload",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tuiparts/core": "workspace:^"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:",
    "@types/bun": "^1.3.14",
    "@types/node": "catalog:",
    "babel-preset-solid": "1.9.12",
    "solid-js": "1.9.12",
    "tsdown": "^0.22.5",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:",
    "solid-js": "1.9.12"
  }
}
