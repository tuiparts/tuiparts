{
  "name": "@opentui-ui/styles",
  "version": "0.0.2",
  "description": "Optional type-safe styling for consumer-owned OpenTUI recipes",
  "author": "Matt Simpson",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msmps/opentui-ui.git",
    "directory": "packages/styles"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "bugs": {
    "url": "https://github.com/msmps/opentui-ui/issues"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/msmps/opentui-ui#readme",
  "keywords": [
    "styles",
    "variants",
    "ui",
    "components",
    "tui",
    "terminal",
    "cli",
    "opentui"
  ],
  "scripts": {
    "bench:assign": "bun run perf/assign-style-props.bench.ts",
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.react.json --noEmit && tsc -p tsconfig.solid.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@opentui/core": "catalog:",
    "@opentui/react": "catalog:",
    "@opentui/solid": "catalog:",
    "@types/bun": "^1.3.14",
    "@types/node": "catalog:",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "solid-js": "1.9.12",
    "tsdown": "^0.22.5",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@opentui/core": "catalog:"
  }
}
