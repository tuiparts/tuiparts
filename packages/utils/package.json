{
  "name": "@tuiparts/utils",
  "version": "0.0.1",
  "private": true,
  "description": "Shared utilities and types for tui.parts packages",
  "author": "Matt Simpson",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuiparts/tuiparts.git",
    "directory": "packages/utils"
  },
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./types": {
        "types": "./dist/types/index.d.mts",
        "import": "./dist/types/index.mjs"
      }
    }
  },
  "bugs": {
    "url": "https://github.com/tuiparts/tuiparts/issues"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/tuiparts/tuiparts#readme",
  "keywords": [
    "utils",
    "utilities",
    "tui",
    "terminal",
    "cli",
    "opentui"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@opentui/core": "catalog:",
    "@types/bun": "^1.3.14",
    "@types/node": "catalog:",
    "tsdown": "^0.22.5",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@opentui/core": "catalog:"
  }
}
