{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "noEmit": true,
    "rootDirs": [
      "badge",
      "button",
      "checkbox",
      "dialog",
      "input",
      "radio-group",
